# ─────────────────────────────────────────────────────────────────────────────
# .env — SpectralSense TVWS
# Cargar con: source .env   (bash)
#         o: python-dotenv  (si se usa desde Python)
#
# NUNCA subir este archivo a GitHub. Agregar .env al .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Rutas del proyecto ───────────────────────────────────────────────────────
TVWS_ROOT=/home/tu_usuario/tvws_ia          # raíz del proyecto — CAMBIAR
TVWS_RAW_IQ=$TVWS_ROOT/raw_iq              # I/Q crudos del RTL-SDR
TVWS_DATASET=$TVWS_ROOT/dataset            # dataset procesado (.npz)
TVWS_MODELOS=$TVWS_ROOT/modelos            # checkpoints y .onnx exportados
TVWS_LOGS=$TVWS_ROOT/logs                  # logs CSV de entrenamiento e inferencia

# ── Hardware de captura ──────────────────────────────────────────────────────
RTL_SDR_SAMPLE_RATE=2400000                # 2.4 MSPS — máximo estable RTL-SDR V4
RTL_SDR_GAIN=auto                          # ganancia automática
RTL_SDR_DEVICE_INDEX=0                     # índice del dispositivo (0 si solo hay uno)

# ── Parámetros del modelo ────────────────────────────────────────────────────
MODEL_PSD_LENGTH=512                       # puntos del vector PSD de entrada
MODEL_N_CANALES=9                          # máximo de canales por sub-banda
MODEL_UMBRAL_LIBRE=0.20                    # prob < umbral → canal libre
MODEL_UMBRAL_SOSPECHOSO=0.65
MODEL_UMBRAL_EMERGENCIA=0.95

# ── Entrenamiento ────────────────────────────────────────────────────────────
TRAIN_EPOCAS=80
TRAIN_BATCH_SIZE=32                        # 32 para CPU; 64 si GPU disponible
TRAIN_LR=0.001
TRAIN_DISPOSITIVO=cpu                      # "cpu" siempre funciona
                                           # cambiar a "cuda" si ROCm funciona en la RX 580

# ── PyTorch / ROCm (solo si se intenta GPU) ──────────────────────────────────
# Descomentar si se instala ROCm 5.7 y PyTorch con soporte gfx803:
# HSA_OVERRIDE_GFX_VERSION=10.3.0          # fuerza reconocimiento de gfx803 en ROCm
# ROCR_VISIBLE_DEVICES=0                   # índice de la GPU AMD visible
# HIP_VISIBLE_DEVICES=0

# ── Numpy / rendimiento ──────────────────────────────────────────────────────
OMP_NUM_THREADS=14                         # hilos OpenMP para numpy/torch en CPU
                                           # Ryzen 7 7700x: 8 núcleos × 2 hilos = 16
                                           # dejar 2 libres para el SO → 14
MKL_NUM_THREADS=14

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                             # DEBUG para desarrollo, INFO para producción
